# Application
APP_NAME=Express Backend
NODE_ENV=development
DEBUG=true

# SQL Database
SQL_HOST=localhost
SQL_USER=
SQL_PASSWORD=
SQL_DATABASE=
SQL_PORT=3306

# Docker MySQL (uncomment if using Docker)
# SQL_HOST=mysql
# SQL_PORT=3306
# SQL_USER=root
# SQL_PASSWORD=Deep@2004
# SQL_DATABASE=recipe_db

# Auth / Security
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=
ALGORITHM=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://192.168.1.7:5173

# Server
PORT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=false
# LOG_FILE_PATH=./logs/app.log

# Elastic APM (disabled for now)
ELASTIC_APM_ENABLED=false
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SERVICE_NAME=
ELASTIC_APM_ENVIRONMENT=

# ELK Stack / Logstash (Remote ELK Server)
# LOGSTASH_HOST=host.docker.internal
# LOGSTASH_PORT=5044
# ELASTICSEARCH_HOST=elasticsearch
# ELASTICSEARCH_PORT=9200
# LOG_ENVIRONMENT=dev
# LOG_SERVICE_NAME=
